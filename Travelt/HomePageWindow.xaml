<Window x:Class="Travelt.HomePageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Travelt"
        mc:Ignorable="d"
        Title="HomePageWindow" Height="450" Width="800">
    
    
    <Grid Background="#1A001F">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <TextBlock x:Name="WelcomeTextBlock"
               Text="Welcome, User"    
               FontSize="120"
               Margin="0,0,70,0"
               Foreground="White"
               FontFamily="Comic Sans MS"
               FontWeight="Bold"
               HorizontalAlignment="Center"/>

                     <!--Ondrej: change "user" for {user}-->

    


        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                Content="Discover"
                Height="140"
                FontSize="22"
                Background="#FF2D8C"
                Foreground="White"
                Click="DiscoverButton_Click"/>

            <Button Grid.Column="2"
                Content="Planning"
                Height="140"
                FontSize="22"
                Background="#FF2D8C"
                Foreground="White"
                Click="PlanningButton_Click"/>

            <Button Grid.Column="4"
                Content="Profile"
                Height="140"
                FontSize="22"
                Background="#FF2D8C"
                Foreground="White"
                Click="ProfileButton_Click"/>

        </Grid>

      



        <StackPanel Grid.Row="2" HorizontalAlignment="Left">



            <TextBlock x:Name="DateTimeTextBlock"
                   Text="DateTime"
                   FontSize="22"
                   Foreground="White"
                   VerticalAlignment="Bottom"
                   FontFamily="Comic Sans MS"/>


            <!--Ondrej: add datetime function here-->

        </StackPanel>

        <StackPanel Grid.Row="4" HorizontalAlignment="Center">


            <TextBlock Text="“Stay consistent. It will pay off.”"
                  FontStyle="Italic"
                  Foreground="white"
                  Margin="0,0,0,0"
                  FontSize="30"/>

            <!--Ondrej: add API for the quote-->

        </StackPanel>

    </Grid>
</Window>
