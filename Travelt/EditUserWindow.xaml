<Window x:Class="Travelt.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit User"
        Height="350"
        Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#1E102D">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <TextBlock Text="Edit User"
                   FontSize="26"
                   FontFamily="Comic Sans MS"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        
        <StackPanel Grid.Row="1">
            <TextBlock Text="Change user's username below:"
                       FontFamily="Comic Sans MS"
                       Foreground="White"
                       Margin="0,0,0,5"/>

            <TextBox x:Name="UsernameText"
                     Height="35"
                     FontSize="16"/>
        </StackPanel>

        
        <StackPanel Grid.Row="2" 
                    Margin="0,20,0,0">
            
            <Button Content="Delete User's Bio"
                    Height="40"
                    FontFamily="Comic Sans MS"
                    Background="#FF2D8C"
                    Foreground="White"
                    Click="DeleteBioButton"/>
        </StackPanel>

        
        <StackPanel Grid.Row="3" 
                    Margin="0,10,0,0">
            
            <Button Content="Delete User's Profile Picture"
                    Height="40"
                    FontFamily="Comic Sans MS"
                    Background="#FF2D8C"
                    Foreground="White"
                    Click="DeleteProfilePictureButton"/>
        </StackPanel>

        
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="Save"
                    Width="100"
                    Height="40"
                    Margin="0,0,10,0"
                    Background="#4CAF50"
                    Foreground="White"
                    Click="SaveButton"/>

            <Button Content="Cancel"
                    Width="100"
                    Height="40"
                    Background="#888"
                    Foreground="White"
                    Click="CancelButton"/>
        </StackPanel>

    </Grid>
</Window>