<Window x:Class="Travelt.DiscoveryPageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Travelt"
        mc:Ignorable="d"
        Title="Discovery Feed" Height="450" Width="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1A001F">
        <ItemsControl x:Name="DiscoverFeed" Margin="0,10">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:PostUI HorizontalAlignment="Center" Width="675"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Window>
