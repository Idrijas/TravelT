<Window x:Class="Travelt.DiscoveryPageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Travelt"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F4F4F4">
        <ItemsControl x:Name="DiscoverFeed" Margin="0,10">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:UserControl1 HorizontalAlignment="Center" Width="450"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Window>
