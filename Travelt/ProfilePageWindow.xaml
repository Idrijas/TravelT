<Window x:Class="TravelT.ProfilePageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Travelt"
        Title="ProfilePageWindow"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1A0B2E">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <TextBlock Text="Your Profile"
                   Foreground="White"
                   FontSize="70"
                   FontFamily="Comic Sans MS"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,25"/>

       
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60*"/>
                <ColumnDefinition Width="40*"/>
            </Grid.ColumnDefinitions>

            
            <Grid Grid.Column="0"
                        Margin="0,25,25,0">   <!-- this is the whole left side of the page-->
                <Grid.RowDefinitions>
                    <RowDefinition Height="441"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Profile pic, play with the padding -->
                
                <Border Background="#2B124C"
                        Padding="75"            
                        Margin="0,0,0,15" 
                        Height="441"
                        Grid.Row="0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- profile pic -->
                        
                        
                        <Border Grid.Column="0"
                                Width="230"
                                Height="230"
                                Background="#FF2D8C"
                                HorizontalAlignment="Center">

                            <TextBlock Text="Profile Picture"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            
                        </Border>

                        <!-- username, age, rank, rating -->
                        
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Left"
                                    Margin="20,0,0,0">

                            <TextBlock x:Name="UsernameBlock"
                                       Text="Username"
                                       Foreground="White"
                                       FontSize="34"
                                       FontFamily="Comic Sans MS"
                                       FontWeight="Bold"
                                       Margin="0,0,0,15"/>

                            <TextBlock x:Name="AgeBlock"
                                       Text="Age: "
                                       Foreground="White"
                                       FontFamily="Comic Sans MS"
                                       FontSize="22"
                                       Margin="0,0,0,8"/>

                            <TextBlock x:Name="RankBlock"
                                       Text="Rank: "
                                       Foreground="White"
                                       FontSize="22"
                                       FontFamily="Comic Sans MS"
                                       Margin="0,5,0,8"/>

                            <TextBlock x:Name="RatingBlock"
                                       Text="Rating: "
                                       Foreground="White"
                                       FontFamily="Comic Sans MS"
                                       FontSize="22"
                                       Margin="0,5,0,8"/>

                            <TextBlock Text="You can edit your profile in Settings :)"
                                       Foreground="White"
                                       FontStyle="Italic"
                                       FontFamily="Comic Sans MS"
                                       FontSize="18"
                                       Margin="0,15,0,8"/>




                        </StackPanel>

      
                       
                    </Grid>
                    
                        
                </Border>

                <Expander Grid.Row="1" Header="Bio"
                          Background="#2B124C"
                          Foreground="White"
                          FontSize="22"
                          FontFamily="Comic Sans MS"
                          Padding="12"
                          Margin="0,0,0,15">
                    
                    

                    <TextBlock x:Name="BioExpander"
                               Text="Here will be Bio, probably max 200 characters (we can talk about it), can be editable"
                               Foreground="White"
                               FontFamily="Comic Sans MS"
                               FontSize="18"
                               TextWrapping="Wrap"
                               Margin="10"/>
                    
                    
                </Expander>

                <Expander Grid.Row="2" Header="Achievements"
                          Background="#2B124C"
                          Foreground="White"
                          FontSize="22"
                          FontFamily="Comic Sans MS"
                          Padding="12"
                          Margin="0,0,0,15">

                    <TextBlock x:Name="AchievementsExpander"
                               Text="Here will be all achievements (I suggest adding icons and when clicked on them -> description"
                               Foreground="White"
                               FontFamily="Comic Sans MS"
                               FontSize="18"
                               TextWrapping="Wrap"
                               Margin="10"/>
                </Expander>


                <Expander Grid.Row="3" Header="Plans"
                            Background="#2B124C"
                            Foreground="White"
                            FontSize="22"
                            FontFamily="Comic Sans MS"
                            Padding="12"
                            Margin="0,0,0,15">

                    <TextBlock x:Name="PlansExpander"
                                Text="Here will be listed plans (not sure how, but they will be there (probably will have to work with plans page))"
                                Foreground="White"
                                FontFamily="Comic Sans MS"
                                FontSize="18"
                                TextWrapping="Wrap"
                                Margin="10"/>
                </Expander>


                

            </Grid>

            <!-- The whole right side of the page -->
            
            <Border Grid.Column="1"
                    Background="#2B124C"
                    Padding="20" 
                    Margin="0,25,0,0">

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="World Map"
                               Foreground="White"
                               FontSize="34"
                               FontFamily="Comic Sans MS"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,85"/>

                    <Border Height="441"
                            Background="#3B1A66"
                            CornerRadius="15">

                        <TextBlock Text="Here will be API for world mapa"
                                   Foreground="White"
                                   FontSize="18"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

        </Grid>

        <!-- Bottom navigation buttons -->
        <Grid Grid.Row="2"
              Margin="0,25,0,0">

            <Button Content="To HomePage"
                    Width="160"
                    Height="45"
                    Foreground="White"
                    Background="#FF2D8C"
                    HorizontalAlignment="Left"
                    Click="ToHomePage_Button"/>

            <Button Content="Settings"
                    Width="160"
                    Height="45"
                    Background="#FF2D8C"
                    Foreground="White"
                    HorizontalAlignment="Right"
                    Click="ToSettings_Button"/>

        </Grid>

    </Grid>
</Window>