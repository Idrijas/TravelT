<UserControl x:Class="Travelt.UserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Travelt"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="400">

    <Border Background="White" 
            CornerRadius="10" 
            Margin="10" 
            BorderBrush="#E0E0E0" 
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2" Direction="-90"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12">
                <Ellipse Width="40" Height="40" Fill="#DDDDDD"/>
                <StackPanel Margin="12,0,0,0">
                    <TextBlock Text="{Binding Username}" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding Timestamp}" Foreground="Gray" FontSize="11"/>
                </StackPanel>
            </StackPanel>

            <Image Grid.Row="1" 
                   Source="{Binding ImagePath}" 
                   Stretch="UniformToFill" 
                   MaxHeight="300" 
                   MinHeight="200"/>

            <StackPanel Grid.Row="2" Margin="12">
                <TextBlock Text="{Binding Description}" 
                           TextWrapping="Wrap" 
                           FontSize="13" 
                           LineHeight="18"/>
            </StackPanel>

            <Border Grid.Row="3" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0" Margin="8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="❤️ Like" Margin="0,0,15,0" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="💬 Comment" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>